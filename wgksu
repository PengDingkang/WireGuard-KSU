#!/system/bin/sh

wg_data="/data/adb/wireguard"
autostart_file="$wg_data/autostart"
stay_awake_file="$wg_data/stayawake"
stay_awake_wakelock_state="$wg_data/stayawake.wakelock"
stay_awake_wifi_state="$wg_data/stayawake.wifi"
log_file="$wg_data/error.log"
reresolve_log="$wg_data/reresolve.log"
wake_lock_name="wgksu_stay_awake"

# resolve wg binary path: prefer PATH, fallback to data dir
if command -v wg >/dev/null 2>&1; then
  WG=wg
else
  WG="$wg_data/wg"
fi

# find busybox across Magisk/KSU/APatch
for bb in /data/adb/magisk/busybox /data/adb/ksu/bin/busybox /data/adb/ap/bin/busybox; do
  [ -f "$bb" ] && busybox="$bb" && break
done
[ -z "$busybox" ] && busybox="busybox"

get_autostart() {
  iface="$1"
  if [ -n "$iface" ] && [ -f "$wg_data/autostart.${iface}" ]; then
    AUTO_START=1
    # shellcheck disable=SC1090
    . "$wg_data/autostart.${iface}"
    echo "${AUTO_START:-1}"
  elif [ -f "$autostart_file" ]; then
    AUTO_START=1
    # shellcheck disable=SC1090
    . "$autostart_file"
    echo "${AUTO_START:-1}"
  else
    echo "1"
  fi
}

set_autostart() {
  mkdir -p "$wg_data"
  if [ -n "$2" ]; then
    printf "AUTO_START=%s\n" "$1" > "$wg_data/autostart.$2"
  else
    printf "AUTO_START=%s\n" "$1" > "$autostart_file"
  fi
}

get_stay_awake() {
  iface="$1"
  if [ -n "$iface" ] && [ -f "$wg_data/stayawake.${iface}" ]; then
    STAY_AWAKE=0
    # shellcheck disable=SC1090
    . "$wg_data/stayawake.${iface}"
    echo "${STAY_AWAKE:-0}"
  elif [ -f "$stay_awake_file" ]; then
    STAY_AWAKE=0
    # shellcheck disable=SC1090
    . "$stay_awake_file"
    echo "${STAY_AWAKE:-0}"
  else
    echo "0"
  fi
}

set_stay_awake() {
  mkdir -p "$wg_data"
  if [ -n "$2" ]; then
    printf "STAY_AWAKE=%s\n" "$1" > "$wg_data/stayawake.$2"
  else
    printf "STAY_AWAKE=%s\n" "$1" > "$stay_awake_file"
  fi
}

# log with interface prefix
wg_log() {
  printf '%s [%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" "$2" >> "$log_file"
}

any_stay_awake_running() {
  for conf in "$wg_data"/*.conf; do
    [ -f "$conf" ] || continue
    iface=$(basename "$conf" .conf)
    iface_running "$iface" || continue
    [ "$(get_stay_awake "$iface")" = "1" ] && return 0
  done
  return 1
}

enable_stay_awake_runtime() {
  mkdir -p "$wg_data"

  if [ -w /sys/power/wake_lock ]; then
    if echo "$wake_lock_name" > /sys/power/wake_lock 2>/dev/null; then
      echo "1" > "$stay_awake_wakelock_state"
    else
      wg_log power "failed to acquire wakelock"
    fi
  else
    wg_log power "/sys/power/wake_lock is not writable"
  fi

  if cmd wifi force-hi-perf-mode enabled >/dev/null 2>&1; then
    echo "1" > "$stay_awake_wifi_state"
  else
    wg_log power "failed to enable Wi-Fi hi-perf mode"
  fi
}

release_stay_awake_runtime() {
  if [ -f "$stay_awake_wakelock_state" ]; then
    if [ -w /sys/power/wake_unlock ]; then
      echo "$wake_lock_name" > /sys/power/wake_unlock 2>/dev/null
    fi
    rm -f "$stay_awake_wakelock_state"
  fi

  if [ -f "$stay_awake_wifi_state" ]; then
    cmd wifi force-hi-perf-mode disabled >/dev/null 2>&1
    rm -f "$stay_awake_wifi_state"
  fi
}

apply_stay_awake_runtime() {
  if any_stay_awake_running; then
    enable_stay_awake_runtime
  else
    release_stay_awake_runtime
  fi
}

endpoint_routes_file() {
  echo "$wg_data/endpoint-routes.$1"
}

endpoint_host() {
  endpoint="$1"
  case "$endpoint" in
    \[*\]*:*) host="${endpoint%%]*}"; echo "${host#[}" ;;
    *) echo "${endpoint%:*}" ;;
  esac
}

endpoint_port() {
  echo "${1##*:}"
}

format_endpoint() {
  addr="$1"
  port="$2"
  if is_ipv6 "$addr"; then
    echo "[${addr}]:${port}"
  else
    echo "${addr}:${port}"
  fi
}

is_ipv4() {
  echo "$1" | awk -F. '
    NF != 4 { exit 1 }
    {
      for (i = 1; i <= 4; i++) {
        if ($i !~ /^[0-9]+$/ || $i < 0 || $i > 255) exit 1
      }
      exit 0
    }
  '
}

is_ipv6() {
  case "$1" in
    *:*) echo "$1" | grep -Eq '^[0-9A-Fa-f:]+$' ;;
    *) return 1 ;;
  esac
}

route_table_dump() {
  family="$1"
  routes=$(ip "-$family" route show table all 2>/dev/null)
  if [ -n "$routes" ]; then
    echo "$routes"
    return
  fi

  ip "-$family" route show 2>/dev/null
  for table in wlan0 eth0 rmnet_data0 rmnet_data1 rmnet_data2 rmnet_data3 rmnet_data4 ccmni0 ccmni1; do
    ip "-$family" route show table "$table" 2>/dev/null
  done
}

get_underlay_default_route() {
  family="$1"
  route_table_dump "$family" | awk '
    $1 == "default" {
      dev = ""; via = "";
      for (i = 1; i <= NF; i++) {
        if ($i == "dev") dev = $(i + 1);
        if ($i == "via") via = $(i + 1);
      }
      if (dev ~ /^(wlan|eth|rmnet|ccmni|usb|rndis)/) {
        score = 50;
        if (dev ~ /^wlan/) score = 10;
        else if (dev ~ /^eth/) score = 20;
        else if (dev ~ /^(rmnet|ccmni)/) score = 30;
        if (via == "") via = "-";
        print score, via, dev;
      }
    }
  ' | sort -n | head -1
}

add_endpoint_route() {
  family="$1"
  iface="$2"
  endpoint_addr="$3"
  routes_tmp="$4"
  [ -n "$endpoint_addr" ] || return

  route=$(get_underlay_default_route "$family")
  if [ -z "$route" ]; then
    wg_log "$iface" "no IPv${family} physical default route available for endpoint $endpoint_addr"
    return
  fi

  via=$(echo "$route" | awk '{print $2}')
  dev=$(echo "$route" | awk '{print $3}')
  if [ "$family" = "6" ]; then
    prefix=128
  else
    prefix=32
  fi

  if [ "$via" = "-" ]; then
    ip "-$family" route replace "$endpoint_addr/$prefix" dev "$dev" 2>>"$log_file" || return
    wg_log "$iface" "endpoint IPv${family} route $endpoint_addr dev $dev"
  else
    ip "-$family" route replace "$endpoint_addr/$prefix" via "$via" dev "$dev" 2>>"$log_file" || return
    wg_log "$iface" "endpoint IPv${family} route $endpoint_addr via $via dev $dev"
  fi

  grep -qx "$family $endpoint_addr" "$routes_tmp" 2>/dev/null || echo "$family $endpoint_addr" >> "$routes_tmp"
}

refresh_endpoint_routes() {
  conf="$1"
  iface="$2"
  old_routes=$(endpoint_routes_file "$iface")
  new_routes="${old_routes}.tmp"

  mkdir -p "$wg_data"
  : > "$new_routes"

  grep -i '^[[:space:]]*Endpoint[[:space:]]*=' "$conf" | while IFS= read -r line; do
    endpoint=$(echo "$line" | sed 's/^[^=]*= *//')
    host=$(endpoint_host "$endpoint")
    if is_ipv4 "$host"; then
      add_endpoint_route 4 "$iface" "$host" "$new_routes"
    elif is_ipv6 "$host"; then
      add_endpoint_route 6 "$iface" "$host" "$new_routes"
    else
      endpoint_addr=$(resolve_host "$host")
      if is_ipv4 "$endpoint_addr"; then
        add_endpoint_route 4 "$iface" "$endpoint_addr" "$new_routes"
      elif is_ipv6 "$endpoint_addr"; then
        add_endpoint_route 6 "$iface" "$endpoint_addr" "$new_routes"
      fi
    fi
  done

  if [ -f "$old_routes" ]; then
    while read -r old_family old_addr; do
      [ -n "$old_family" ] || continue
      if [ -z "$old_addr" ]; then
        old_addr="$old_family"
        old_family=4
      fi
      grep -qx "$old_family $old_addr" "$new_routes" 2>/dev/null && continue
      if [ "$old_family" = "6" ]; then
        ip -6 route del "$old_addr/128" 2>/dev/null
      else
        ip -4 route del "$old_addr/32" 2>/dev/null
      fi
    done < "$old_routes"
  fi
  mv "$new_routes" "$old_routes"
}

remove_endpoint_routes() {
  iface="$1"
  routes_file=$(endpoint_routes_file "$iface")
  [ -f "$routes_file" ] || return
  while read -r family endpoint_addr; do
    [ -n "$family" ] || continue
    if [ -z "$endpoint_addr" ]; then
      endpoint_addr="$family"
      family=4
    fi
    if [ "$family" = "6" ]; then
      ip -6 route del "$endpoint_addr/128" 2>/dev/null
    else
      ip -4 route del "$endpoint_addr/32" 2>/dev/null
    fi
  done < "$routes_file"
  rm -f "$routes_file"
}

# --- wg-quick replacement for Android (sh-based) ---

# parse a .conf file and extract Interface/Peer sections
wg_up() {
  conf="$1"
  iface="$2"

  if ip link show "$iface" >/dev/null 2>&1; then
    echo "$iface is already up"
    return
  fi

  if [ ! -f "$conf" ]; then
    echo "ERROR: config not found: $conf"
    return 1
  fi

  # basic config validation
  if ! grep -qi '^[[:space:]]*\[Interface\]' "$conf"; then
    echo "ERROR: missing [Interface] section in $conf"
    return 1
  fi
  if ! grep -qi '^[[:space:]]*PrivateKey' "$conf"; then
    echo "ERROR: missing PrivateKey in $conf"
    return 1
  fi
  if grep -q 'REPLACE_WITH_' "$conf"; then
    echo "ERROR: $conf still has placeholder values, edit before starting"
    return 1
  fi
  if ! grep -qi '^[[:space:]]*\[Peer\]' "$conf"; then
    echo "ERROR: missing [Peer] section in $conf"
    return 1
  fi

  # extract Interface fields
  address=$(grep -i '^[[:space:]]*Address' "$conf" | sed 's/^[^=]*= *//' | tr -d ' ')
  dns=$(grep -i '^[[:space:]]*DNS' "$conf" | sed 's/^[^=]*= *//' | tr -d ' ')
  mtu=$(grep -i '^[[:space:]]*MTU' "$conf" | sed 's/^[^=]*= *//' | tr -d ' ')

  # create interface
  if ! ip link add "$iface" type wireguard 2>"$log_file"; then
    wg_log "$iface" "failed to create WireGuard interface (kernel support missing?)"
    echo "ERROR: failed to create WireGuard interface (kernel support missing?)"
    cat "$log_file" 2>/dev/null
    return 1
  fi

  # apply wg config (strip Interface-only fields, pass to wg setconf)
  tmpconf="/tmp/wg_${iface}.conf"
  awk '
    { gsub(/\r/, "") }
    /^[[:space:]]*\[/ { print; next }
    /^[[:space:]]*#/ { next }
    /^[[:space:]]*$/ { print; next }
    {
      key = $1
      gsub(/[[:space:]]*=.*/, "", key)
      lk = tolower(key)
      if (lk == "privatekey" || lk == "listenport" || lk == "fwmark" || \
          lk == "publickey" || lk == "presharedkey" || lk == "allowedips" || \
          lk == "endpoint" || lk == "persistentkeepalive") print
    }
  ' "$conf" > "$tmpconf"

  # pre-resolve domain endpoints (wg binary may not have working DNS)
  while IFS= read -r line; do
    case "$line" in
      *[Ee]ndpoint*=*)
        ep=$(echo "$line" | sed 's/^[^=]*= *//')
        host=$(endpoint_host "$ep")
        port=$(endpoint_port "$ep")
        if ! is_ipv4 "$host" && ! is_ipv6 "$host"; then
          resolved=$(resolve_host "$host")
          if [ -n "$resolved" ]; then
            line="Endpoint = $(format_endpoint "$resolved" "$port")"
          fi
        fi
        ;;
    esac
    printf '%s\n' "$line"
  done < "$tmpconf" > "${tmpconf}.resolved"
  mv "${tmpconf}.resolved" "$tmpconf"

  refresh_endpoint_routes "$tmpconf" "$iface"

  $WG setconf "$iface" "$tmpconf" 2>>"$log_file"
  wg_setconf_ret=$?
  rm -f "$tmpconf"

  if [ "$wg_setconf_ret" -ne 0 ]; then
    wg_log "$iface" "wg setconf failed"
    echo "ERROR: wg setconf failed for $iface"
    ip link del "$iface" 2>/dev/null
    return 1
  fi

  # set addresses
  IFS=','
  for addr in $address; do
    addr=$(echo "$addr" | tr -d ' ')
    [ -n "$addr" ] && ip addr add "$addr" dev "$iface" 2>>"$log_file"
  done
  unset IFS

  # set MTU
  [ -n "$mtu" ] && ip link set "$iface" mtu "$mtu"
  [ -z "$mtu" ] && ip link set "$iface" mtu 1420

  # bring up
  ip link set "$iface" up

  # add routes for AllowedIPs
  $WG show "$iface" allowed-ips 2>/dev/null | while read -r _ ips; do
    for cidr in $ips; do
      [ "$cidr" = "(none)" ] && continue
      case "$cidr" in
        *:*) ip -6 route add "$cidr" dev "$iface" 2>/dev/null ;;
        *)   ip -4 route add "$cidr" dev "$iface" 2>/dev/null ;;
      esac
    done
  done

  # DNS (set system property for Android)
  if [ -n "$dns" ]; then
    i=1
    IFS=','
    for d in $dns; do
      d=$(echo "$d" | tr -d ' ')
      ndc resolver setnetdns "$iface" "" "$d" 2>/dev/null || \
        setprop net.dns${i} "$d" 2>/dev/null
      i=$((i + 1))
    done
    unset IFS
  fi

  # routing policy
  ip rule add from all lookup main pref 1 2>/dev/null

  echo "$iface up"
}

wg_down() {
  iface="$1"

  if ! ip link show "$iface" >/dev/null 2>&1; then
    echo "$iface is not up"
    return
  fi

  ip link set "$iface" down 2>/dev/null
  ip link del "$iface" 2>/dev/null
  remove_endpoint_routes "$iface"
  ip rule del from all lookup main pref 1 2>/dev/null

  echo "$iface down"
}

# --- list available configs ---
list_configs() {
  for f in "$wg_data"/*.conf; do
    [ -f "$f" ] && basename "$f" .conf
  done
}

# --- interface status ---
iface_running() {
  ip link show "$1" >/dev/null 2>&1
}

any_running() {
  for conf in "$wg_data"/*.conf; do
    [ -f "$conf" ] || continue
    iface=$(basename "$conf" .conf)
    iface_running "$iface" && return 0
  done
  return 1
}

# --- update KSU description ---
update_desc() {
  command -v ksud >/dev/null 2>&1 || return
  export KSU_MODULE="WireGuard-KSU"
  if any_running; then
    desc=""
    for conf in "$wg_data"/*.conf; do
      [ -f "$conf" ] || continue
      iface=$(basename "$conf" .conf)
      if iface_running "$iface"; then
        ip=$(ip -4 addr show "$iface" 2>/dev/null | grep -o 'inet [^ ]*' | head -1 | cut -d' ' -f2 | cut -d/ -f1)
        if [ -n "$desc" ]; then desc="$desc | "; fi
        desc="${desc}${iface}: ${ip:-?}"
      fi
    done
    ksud module config set override.description "✅ Running | ${desc}" 2>/dev/null
  else
    ksud module config set override.description "⏹ Stopped" 2>/dev/null
  fi
}

# --- commands ---
start_all() {
  started=0
  for conf in "$wg_data"/*.conf; do
    [ -f "$conf" ] || continue
    iface=$(basename "$conf" .conf)
    wg_up "$conf" "$iface"
    started=1
  done
  [ "$started" = "0" ] && echo "No .conf files found in $wg_data"
}

stop_all() {
  for conf in "$wg_data"/*.conf; do
    [ -f "$conf" ] || continue
    iface=$(basename "$conf" .conf)
    iface_running "$iface" && wg_down "$iface"
  done
}

show_status() {
  found=0
  for conf in "$wg_data"/*.conf; do
    [ -f "$conf" ] || continue
    iface=$(basename "$conf" .conf)
    found=1
    if iface_running "$iface"; then
      printf "\033[32m● %s is up\033[0m\n" "$iface"
      $WG show "$iface" 2>/dev/null | sed 's/^/  /'
    else
      printf "\033[31m● %s is down\033[0m\n" "$iface"
    fi
  done
  [ "$found" = "0" ] && echo "No .conf files found in $wg_data"
  echo ""
  for conf in "$wg_data"/*.conf; do
    [ -f "$conf" ] || continue
    iface=$(basename "$conf" .conf)
    if [ "$(get_autostart "$iface")" = "1" ]; then
      printf "● %s boot auto start: enabled\n" "$iface"
    else
      printf "● %s boot auto start: disabled\n" "$iface"
    fi
    if [ "$(get_stay_awake "$iface")" = "1" ]; then
      printf "● %s stay awake: enabled\n" "$iface"
    else
      printf "● %s stay awake: disabled\n" "$iface"
    fi
  done
  update_desc
}

# --- DNS re-resolve for domain endpoints ---
# resolve hostname to IP using available Android tools
resolve_host4() {
  host="$1"
  addr=$(ping -c1 -W2 "$host" 2>/dev/null | grep -oE '\([0-9]+(\.[0-9]+){3}\)' | head -1 | tr -d '()')
  [ -n "$addr" ] && echo "$addr" && return
  addr=$(getent hosts "$host" 2>/dev/null | awk '{ for (i = 1; i <= NF; i++) if ($i ~ /^[0-9]+(\.[0-9]+){3}$/) { print $i; exit } }')
  [ -n "$addr" ] && echo "$addr" && return
  addr=$($busybox nslookup "$host" 2>/dev/null | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' | tail -1)
  [ -n "$addr" ] && echo "$addr"
}

resolve_host6() {
  host="$1"
  if command -v ping6 >/dev/null 2>&1; then
    addr=$(ping6 -c1 -W2 "$host" 2>/dev/null | grep -oE '([0-9A-Fa-f]{0,4}:){2,}[0-9A-Fa-f:]+' | head -1)
    [ -n "$addr" ] && echo "$addr" && return
  fi
  addr=$(getent hosts "$host" 2>/dev/null | awk '{ for (i = 1; i <= NF; i++) if ($i ~ /^[0-9A-Fa-f:]*:[0-9A-Fa-f:]*$/) { print $i; exit } }')
  [ -n "$addr" ] && echo "$addr" && return
  addr=$($busybox nslookup "$host" 2>/dev/null | grep -oE '([0-9A-Fa-f]{0,4}:){2,}[0-9A-Fa-f:]+' | tail -1)
  [ -n "$addr" ] && echo "$addr"
}

resolve_host() {
  host="$1"
  addr=$(resolve_host4 "$host")
  [ -n "$addr" ] && echo "$addr" && return
  resolve_host6 "$host"
}

# re-resolve domain endpoints for running interfaces, update if IP changed
reresolve_dns() {
  filter="$1"
  for conf in "$wg_data"/*.conf; do
    [ -f "$conf" ] || continue
    iface=$(basename "$conf" .conf)
    [ -n "$filter" ] && [ "$filter" != "$iface" ] && continue
    iface_running "$iface" || continue
    refresh_endpoint_routes "$conf" "$iface"

    # parse each peer's public key and endpoint from conf
    awk '
      { gsub(/\r/, "") }
      /^\[Peer\]/       { peer=1; pk=""; ep=""; next }
      /^\[/             { if(peer && pk && ep) print pk " " ep; peer=0; next }
      peer && /^[[:space:]]*PublicKey/  { gsub(/.*= */, ""); pk=$0 }
      peer && /^[[:space:]]*Endpoint/  { gsub(/.*= */, ""); ep=$0 }
      END { if(peer && pk && ep) print pk " " ep }
    ' "$conf" | while read -r pubkey endpoint; do
      # split host:port — skip if endpoint is already a raw IP
      host=$(endpoint_host "$endpoint")
      port=$(endpoint_port "$endpoint")
      is_ipv4 "$host" && continue
      is_ipv6 "$host" && continue

      new_ip=$(resolve_host "$host")
      [ -z "$new_ip" ] && continue

      # get current endpoint IP from wg show
      cur=$($WG show "$iface" endpoints 2>/dev/null | grep "^${pubkey}" | awk '{print $2}')
      cur_ip=$(endpoint_host "$cur")

      if [ "$new_ip" != "$cur_ip" ]; then
        $WG set "$iface" peer "$pubkey" endpoint "$(format_endpoint "$new_ip" "$port")" 2>>"$log_file"
        echo "[reresolve] $iface: $host changed $cur_ip -> $new_ip"
        echo "$(date '+%Y-%m-%d %H:%M:%S') $iface: $host $cur_ip -> $new_ip" >> "$reresolve_log"
      fi
    done
  done
}

case "$1" in
  start)
    if [ -n "$2" ]; then
      wg_up "$wg_data/$2.conf" "$2"
    else
      start_all
    fi
    apply_stay_awake_runtime
    update_desc
    ;;
  stop)
    if [ -n "$2" ]; then
      wg_down "$2"
    else
      stop_all
    fi
    apply_stay_awake_runtime
    update_desc
    ;;
  restart)
    if [ -n "$2" ]; then
      wg_down "$2"; wg_up "$wg_data/$2.conf" "$2"
    else
      stop_all; start_all
    fi
    apply_stay_awake_runtime
    update_desc
    ;;
  status)  show_status ;;
  enable)  set_autostart 1 "$2"; echo "boot auto start: enabled${2:+ ($2)}" ;;
  disable) set_autostart 0 "$2"; echo "boot auto start: disabled${2:+ ($2)}" ;;
  stay-awake)
    case "$2" in
      enable|on|1|true)
        set_stay_awake 1 "$3"
        echo "stay awake: enabled${3:+ ($3)}"
        apply_stay_awake_runtime
        ;;
      disable|off|0|false)
        set_stay_awake 0 "$3"
        echo "stay awake: disabled${3:+ ($3)}"
        apply_stay_awake_runtime
        ;;
      status|"")
        if [ -n "$3" ]; then
          echo "stay awake ${3}: $(get_stay_awake "$3")"
        else
          for conf in "$wg_data"/*.conf; do
            [ -f "$conf" ] || continue
            iface=$(basename "$conf" .conf)
            echo "stay awake ${iface}: $(get_stay_awake "$iface")"
          done
        fi
        ;;
      *)
        echo "Usage: wgksu stay-awake {enable|disable|status} [interface]"
        exit 1
        ;;
    esac
    ;;
  apply-stay-awake)
    apply_stay_awake_runtime
    ;;
  genkey)
    privkey=$($WG genkey)
    pubkey=$(echo "$privkey" | $WG pubkey)
    echo "Private Key: $privkey"
    echo "Public Key:  $pubkey"
    ;;
  reresolve-dns)
    reresolve_dns "$2"
    ;;
  reresolve-log)
    tail -50 "$reresolve_log" 2>/dev/null || echo "No re-resolve log"
    ;;
  *)       echo "Usage: wgksu {start|stop|restart|status|enable|disable|stay-awake|genkey|reresolve-dns} [interface]" ;;
esac
